{
  "name": "imsc-script",
  "type": "module",
  "version": "1.0.1",
  "description": "JS library to play dialogs/scripts created in IMS Creators",
  "author": "ImStocker <support@cr5.space>",
  "license": "MIT",
  "homepage": "https://github.com/ImStocker/imsc-script-js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ImStocker/imsc-script-js.git"
  },
  "bugs": {
    "url": "https://github.com/ImStocker/imsc-script-js/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./Graph": {
      "import": "./dist/Graph.mjs",
      "require": "./dist/Graph.cjs"
    },
    "./Props": {
      "import": "./dist/Props.mjs",
      "require": "./dist/Props.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "bumpp": "^11.0.1",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts"
}
